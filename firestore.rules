rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    match /challenges/{id} {
      // Permitir leer si eres el que envía o el que recibe
      allow read: if isAuth() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      // Permitir crear si el fromUid eres tú
      allow create: if isAuth() && request.resource.data.fromUid == request.auth.uid;
      // Permitir actualizar/borrar si eres parte del desafío
      allow update, delete: if isAuth() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    match /fights/{id} {
      // Permitir leer si estás en la lista de jugadores (players array)
      allow read: if isAuth() && (request.auth.uid in resource.data.players);
      // Permitir crear si eres uno de los jugadores
      allow create: if isAuth() && (request.auth.uid in request.resource.data.players);
      // Permitir actualizar si eres uno de los jugadores
      allow update: if isAuth() && (request.auth.uid in resource.data.players);
    }
  }
}
